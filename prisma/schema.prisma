generator client {
  provider = "prisma-client"
  output   = "../lib/prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//
// ==========================
// ENUMS
// ==========================
//

enum ProductStatus {
  ACTIVE
  ARCHIVED
  OUT_OF_STOCK
}

enum PriceUnit {
  UNIT
  KG
  L
}

//
// ==========================
// CATEGORIES & PRODUCTS
// ==========================
//
model Category {
  id       String     @id @default(uuid())
  name     String
  slug     String     @unique
  position Int        @default(0)
  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")

  products Product[]
  images   Image[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, parentId])
  @@index([parentId])
  @@map("category")
}

model Product {
  id          String    @id @default(uuid())
  name        String
  slug        String
  description String?   @db.Text
  price       Decimal   @db.Decimal(16, 2)
  priceUnit   PriceUnit @default(UNIT)

  status      ProductStatus @default(ACTIVE)
  isPromotion Boolean       @default(false)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  images Image[]
  brands Brand[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, categoryId])
  @@index([categoryId])
  @@index([updatedAt])
  @@map("product")
}

model Image {
  id               String  @id @default(uuid())
  url              String
  altText          String?
  index            Int     @default(0)
  shortDescription String? @db.VarChar(255)
  metaTitle        String?
  metaDescription  String?

  // Relationships
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: Cascade)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([brandId])
  @@index([categoryId])
  @@map("image")
}

model Brand {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  images   Image[]
  products Product[]
}
