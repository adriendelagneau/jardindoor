generator client {
  provider = "prisma-client"
  output   = "../lib/prisma/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//
// ==========================
// AUTHENTICATION
// ==========================
//


//
// ==========================
// AUTH & USERS
// ==========================
//

enum Role {
  USER
  ADMIN
}

model User {
  id    String @id @default(uuid())
  email String @unique

  name          String?
  password      String?
  role          Role    @default(USER)
  emailVerified Boolean @default(false)
  image         String?

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
  accounts Account[]


  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id         String @id @default(uuid())
  accountId  String
  providerId String

  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  purpose    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("verification")
}

//
// ==========================
// ENUMS
// ==========================
//

enum ProductStatus {
  ACTIVE
  ARCHIVED
  OUT_OF_STOCK
}

enum PriceUnit {
  UNIT
  KG
  L
}

//
// ==========================
// CATEGORIES & PRODUCTS
// ==========================
//

model Category {
  id          String  @id @default(uuid())
  name        String
  slug        String
  description String? @db.Text
  position    Int     @default(0)

  // SEO Metadata
  metaTitle       String?
  metaDescription String?

  parentId String?
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryTree")

  products Product[]
  images   Image[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, parentId])
  @@index([parentId])
  @@map("category")
}

model Product {
  id          String    @id @default(uuid())
  name        String
  slug        String
  description String?   @db.Text
  price       Decimal   @db.Decimal(16, 2)
  priceUnit   PriceUnit @default(UNIT)

  status      ProductStatus @default(ACTIVE)
  publishedAt DateTime?
  isPromotion Boolean       @default(false)

  // SEO Metadata
  metaTitle       String?
  metaDescription String?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  images  Image[]
  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, categoryId])
  @@index([categoryId])
  @@index([updatedAt])
  @@map("product")
}

model Image {
  id      String  @id @default(uuid())
  url     String
  fileKey String?

  // Media Metadata
  originalName String?
  mimeType     String?
  fileSize     Int?
  width        Int?
  height       Int?

  // Usage Metadata
  altText          String?
  index            Int     @default(0)
  shortDescription String? @db.VarChar(255)
  metaTitle        String?
  metaDescription  String?

  // Relations
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: Cascade)

  brandId String?
  brand   Brand?  @relation(fields: [brandId], references: [id], onDelete: SetNull)

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([brandId])
  @@index([categoryId])
  @@map("image")
}

model Brand {
  id   String @id @default(uuid())
  name String @unique
  slug String @unique

  images   Image[]
  products Product[]
}